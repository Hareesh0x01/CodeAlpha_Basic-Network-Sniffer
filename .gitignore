# --------------------------------------------------
# Basic Network Sniffer — .gitignore
# --------------------------------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
.ruff_cache/

# Environments
.env
.venv
env/
venv/
ENV/

# Sniffer specific: logs and exported data
logs/
output/
*.log
*.pcap
*.csv
*.json

# IDE / OS files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
